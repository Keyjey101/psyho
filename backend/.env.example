# ZAI / GLM
ZAI_API_KEY=your-zai-api-key
ZAI_BASE_URL=https://api.zai.chat/v1
ZAI_MODEL=glm-5
ZAI_SMALL_MODEL=glm-4-flash

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin
ADMIN_EMAILS=

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP (local Postfix relay in Docker)
SMTP_HOST=mail
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ekbmassage.online
SMTP_TLS=false

# DB
DATABASE_URL=sqlite+aiosqlite:///./data/psyho.db
